# Database
DATABASE_URL=postgresql://sportsadmin:sportsadmin@localhost:5432/sportsadmin

# Auth
SESSION_SECRET=replace-with-a-random-64-character-string

# App
PORT=3000
APP_ENV=development

# Session
SESSION_MAX_AGE_MS=28800000

# Password hashing
PASSWORD_HASH_COST=12

# CORS
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=info

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Seed — set these before running `npm run db:seed` to create the initial admin user
DATABASE_SEED_ADMIN_EMAIL=admin@example.com
DATABASE_SEED_ADMIN_PASSWORD=changeme

# Email (optional — for password reset)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# PUBLIC_URL=http://localhost:5173
