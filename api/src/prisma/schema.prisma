generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ─────────────────────────────────────────────────────────────

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  role         UserRole @default(viewer)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  carnivals UserCarnival[]

  @@map("users")
}

model UserCarnival {
  id         Int @id @default(autoincrement())
  userId     Int @map("user_id")
  carnivalId Int @map("carnival_id")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  carnival Carnival @relation(fields: [carnivalId], references: [id], onDelete: Cascade)

  @@unique([userId, carnivalId])
  @@map("user_carnivals")
}

enum UserRole {
  admin
  coordinator
  operator
  viewer
}

// ─── Carnivals ────────────────────────────────────────────────────────────────

model Carnival {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  settings            CarnivalSettings?
  houses              House[]
  users               UserCarnival[]
  competitors         Competitor[]
  competitorEventAges CompetitorEventAge[]

  @@map("carnivals")
}

model CarnivalSettings {
  carnivalId       Int     @id @map("carnival_id")
  title            String  @db.VarChar(100)
  footer           String? @db.VarChar(100)
  openAge          Int     @default(99) @map("open_age")
  houseTypeId      Int?    @map("house_type_id")
  alertToRecord    Boolean @default(true) @map("alert_to_record")
  reportHead1      String  @default("Lane") @map("report_head_1") @db.VarChar(50)
  reportHead2      String  @default("Time") @map("report_head_2") @db.VarChar(50)
  meetManagerTeam  String? @map("meet_manager_team") @db.VarChar(30)
  meetManagerCode  String? @map("meet_manager_code") @db.VarChar(4)
  meetManagerTop   Int     @default(3) @map("meet_manager_top")
  htmlExportEnabled Boolean @default(false) @map("html_export_enabled")
  htmlReportHeader String? @map("html_report_header") @db.VarChar(50)
  publicAccess     Boolean @default(false) @map("public_access")
  ageCutoffMonth   Int     @default(1) @map("age_cutoff_month")
  ageCutoffDay     Int     @default(1) @map("age_cutoff_day")

  carnival Carnival @relation(fields: [carnivalId], references: [id], onDelete: Cascade)

  @@map("carnival_settings")
}

// ─── Houses ───────────────────────────────────────────────────────────────────

model House {
  id              Int     @id @default(autoincrement())
  carnivalId      Int     @map("carnival_id")
  code            String  @db.VarChar(7)
  name            String  @db.VarChar(50)
  houseTypeId     Int?    @map("house_type_id")
  include         Boolean @default(true)
  details         String?
  lane            Int?
  competitionPool Int?    @map("competition_pool")
  flag            Boolean @default(false)

  carnival        Carnival         @relation(fields: [carnivalId], references: [id], onDelete: Cascade)
  houseType       HouseType?       @relation(fields: [houseTypeId], references: [id])
  pointsExtra     HousePointsExtra[]
  competitors     Competitor[]

  @@unique([carnivalId, code])
  @@map("houses")
}

model HousePointsExtra {
  id      Int     @id @default(autoincrement())
  houseId Int     @map("house_id")
  points  Float
  reason  String?

  house House @relation(fields: [houseId], references: [id], onDelete: Cascade)

  @@map("house_points_extra")
}

// ─── Reference / Seed tables ──────────────────────────────────────────────────

model Unit {
  id            Int     @id @default(autoincrement())
  name          String  @unique
  label         String
  sortAscending Boolean @map("sort_ascending")

  @@map("units")
}

model HouseType {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  houses House[]

  @@map("house_types")
}

model FinalLevelLabel {
  level Int    @id
  label String

  @@map("final_level_labels")
}

// ─── Competitors ──────────────────────────────────────────────────────────────

model Competitor {
  id          Int       @id @default(autoincrement())
  carnivalId  Int       @map("carnival_id")
  givenName   String    @map("given_name") @db.VarChar(30)
  surname     String    @db.VarChar(30)
  sex         String    @db.Char(1)
  age         Int
  dob         DateTime? @db.Date
  houseId     Int       @map("house_id")
  houseCode   String    @map("house_code") @db.VarChar(10)
  include     Boolean   @default(true)
  totalPoints Float     @map("total_points") @default(0)
  externalId  String?   @map("external_id") @db.VarChar(50)
  comments    String?   @db.VarChar(100)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  carnival    Carnival  @relation(fields: [carnivalId], references: [id], onDelete: Cascade)
  house       House     @relation(fields: [houseId], references: [id], onDelete: Restrict)

  @@map("competitors")
}

model CompetitorEventAge {
  carnivalId     Int     @map("carnival_id")
  competitorAge  Int     @map("competitor_age")
  eventAge       String  @map("event_age") @db.VarChar(20)
  flag           Boolean @default(true)
  tag            Boolean @default(false)
  meetManagerDiv String? @map("meet_manager_division") @db.VarChar(2)

  carnival       Carnival @relation(fields: [carnivalId], references: [id], onDelete: Cascade)

  @@id([carnivalId, competitorAge, eventAge])
  @@map("competitor_event_age")
}
